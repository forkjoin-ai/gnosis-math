-- Generators: a 2T half-integer unit (1+i+j+k)/2 (×2 = ⟨1,1,1,1⟩) and one face unit
-- (e₀+e₁)/√2 (×2 = ⟨√2,√2,0,0⟩ = ⟨⟨0,1⟩,⟨0,1⟩,0,0⟩).
def gT : QZ := ⟨⟨1,0⟩, ⟨1,0⟩, ⟨1,0⟩, ⟨1,0⟩⟩
def gF : QZ := ⟨⟨0,1⟩, ⟨0,1⟩, ⟨0,0⟩, ⟨0,0⟩⟩
def gens2 : List QZ := [gT, gF]
def qOne  : QZ := ⟨⟨2,0⟩, ⟨0,0⟩, ⟨0,0⟩, ⟨0,0⟩⟩
def qNeg1 : QZ := ⟨⟨-2,0⟩, ⟨0,0⟩, ⟨0,0⟩, ⟨0,0⟩⟩

theorem octa_card : octa.length = 48 := by decide

/-- 2O is closed under (scaled) multiplication by each GENERATOR. With the universal
    homomorphism, generator closure pins the group (240 → here 96 checks, not 2304). -/
theorem octa_gen_closed :
    (octa.all (fun a => gens2.all (fun g => octa.contains (qmulS a g)))) = true := by decide

end Cover2

-- ════════ Kernel = {±1}, image = octahedral O ≅ S₄ (24), cover index 2 ════════
namespace Cover2
open GR ZSqrt2

def RIdent : M3 := RmatZ qOne

def octaKernel : List QZ := octa.filter (fun q => decide (RmatZ q = RIdent))

def nubM3 (l : List M3) : List M3 :=
  l.foldl (fun acc m => if acc.contains m then acc else acc ++ [m]) []
def octaImage : List M3 := nubM3 (octa.map RmatZ)

theorem octa_kernel_is_pm_one :
    octaKernel = [qOne, qNeg1] ∧ octaKernel.length = 2 := by
  refine ⟨by decide, by decide⟩

theorem octa_neg_invariant :
    (octa.all (fun q => decide (RmatZ q = RmatZ (qnegZ q)))) = true := by decide

theorem octa_image_card_is_24 :
    octaImage.length = 24 ∧ octa.length / octaImage.length = 2 := by
  refine ⟨by decide, by decide⟩

end Cover2

-- ════════════════════════════════════════════════════════════
-- §  Master certificate — the 2O cover, computed
-- ════════════════════════════════════════════════════════════

namespace Cover2
open GR ZSqrt2

/-- **SPINOR-COVER-2O (master).** The SU(2) → SO(3) double cover realized by EXACT ℤ[√2]
    conjugation rotation `RmatZ` on the binary octahedral group 2O (the 48 octahedral
    units):

      (a) UNIVERSAL HOMOMORPHISM: `RmatZ (qmulZ p q) = mmulZ (RmatZ p) (RmatZ q)` for
          EVERY pair of ℤ[√2]-quaternions (`hom_bridge2`) — polynomial identity, NOT the
          2304 sampled pairs of 2O.
      (b) CLOSURE: the explicit 48-element octahedral list has length 48 (`octa_card`) and
          is closed under multiplication by the two generators (`octa_gen_closed`).
      (c) `RmatZ q = RmatZ (−q)` for every octahedral unit (`octa_neg_invariant`), so −1
          lies in the kernel and the cover is (at least) 2:1.
      (d) KERNEL = {±1}: exactly the two central units map to the identity rotation
          (`octa_kernel_is_pm_one`).
      (e) IMAGE = 24 = |O| = |S₄| (the octahedral rotation group), cover index 48 / 24 = 2
          (`octa_image_card_is_24`).

    This is the COMPUTED conjugation lift of the order-level shadow in `OrientationE8Bridge`
    (`binary_is_2to1_spin_cover` for the octahedral case); it is the finite restriction of
    the continuous cover, not the continuous cover. -/
theorem spinor_cover_2O_master :
    (∀ p q : QZ, RmatZ (qmulZ p q) = mmulZ (RmatZ p) (RmatZ q))
    ∧ octa.length = 48
    ∧ (octa.all (fun a => gens2.all (fun g => octa.contains (qmulS a g)))) = true
    ∧ (octa.all (fun q => decide (RmatZ q = RmatZ (qnegZ q)))) = true
    ∧ (octaKernel = [qOne, qNeg1] ∧ octaKernel.length = 2)
    ∧ (octaImage.length = 24 ∧ octa.length / octaImage.length = 2) := by
  refine ⟨hom_bridge2, octa_card, octa_gen_closed, octa_neg_invariant,
          octa_kernel_is_pm_one, octa_image_card_is_24⟩

/-- **The computed 2O cover index equals the order-level shadow.** The index 2 computed
    here from the conjugation rotation (`|2O| / |image| = 48 / 24 = 2`) equals the tabulated
    `Gnosis.OrientationE8Bridge.spinCoverIndex`, and the carrier/image counts match the
    order-arithmetic `subgroupOrder .BinaryOcta / rotationOrder .Octa = 48 / 24`. The
    conjugation computation reproduces — and lifts — `binary_is_2to1_spin_cover` for the
    octahedral case. -/
theorem octa_cover_index_ties_to_shadow :
    octa.length / octaImage.length = Gnosis.OrientationE8Bridge.spinCoverIndex
    ∧ octa.length = ADEMcKayCorrespondence.subgroupOrder .BinaryOcta 0
    ∧ octaImage.length = Gnosis.OrientationE8Bridge.rotationOrder .Octa
    ∧ octa.length / octaImage.length
        = ADEMcKayCorrespondence.subgroupOrder .BinaryOcta 0
            / Gnosis.OrientationE8Bridge.rotationOrder .Octa := by
  refine ⟨by decide, by decide, by decide, by decide⟩

end Cover2

