/-! ### `WisdomPrimitive` (triad / fork–race–fold)

Definitional hook only — see module doc for witness tree / bearing tree / testimony pointers. -/

theorem wisdom_primitive_fold_yields_wisdom :
    WisdomPrimitive.resultOf WisdomPrimitive.Choice.fold
      = WisdomPrimitive.TriadPrimitive.wisdom :=
  WisdomPrimitive.wisdom_is_derivable

/-- Payoff ring for pure choices: integrate then take `bearingPower` on the triad image. -/
def wisdomChoiceBearingPayoff (c : WisdomPrimitive.Choice) : Nat :=
  WisdomPrimitive.bearingPower (WisdomPrimitive.resultOf c)

/--
  Fold **strictly dominates** fork and race: integrator payoff `2`, failure-phase `1`, invariant `0`.
-/
theorem fold_choice_strictly_dominates_fork_and_race_on_bearing_power :
    wisdomChoiceBearingPayoff WisdomPrimitive.Choice.fold
      > wisdomChoiceBearingPayoff WisdomPrimitive.Choice.fork
    ∧ wisdomChoiceBearingPayoff WisdomPrimitive.Choice.fold
      > wisdomChoiceBearingPayoff WisdomPrimitive.Choice.race := by
  simp [wisdomChoiceBearingPayoff, WisdomPrimitive.resultOf, WisdomPrimitive.bearingPower]

/-- Matches three sequential beats (`toyYoungerBrotherIndex` … `toyFatherBeatIndex`) as fork width `K`. -/
def prodigalThreeBeatForkWidth : Nat := 3

theorem buleyean_failure_info_strictly_dominates_selection_for_three_beats :
    Gnosis.RL.rejectionInfo prodigalThreeBeatForkWidth > Gnosis.RL.selectionInfo prodigalThreeBeatForkWidth :=
  Gnosis.RL.failure_more_informative prodigalThreeBeatForkWidth (by decide : 3 ≥ 3)

/-! ### God formula (`godWeight R v = R - min v R + 1`) -/

theorem mnemonic_three_beats_ceiling :
    godWeight toyBeatBudget 0 = toyFatherBeatIndex + 1 := by
  rw [godWeight_ceiling]
  rfl

theorem godweight_two_son_slots_floor : godWeight toyBeatBudget toyBeatBudget = 1 :=
  godWeight_floor toyBeatBudget

theorem one_pass_rejection_conservation :
    godWeight toyBeatBudget 1 + 1 = toyBeatBudget + 1 :=
  godWeight_conservation toyBeatBudget 1 (by decide)

theorem prodigal_god_formula_bundle :
    godWeight toyBeatBudget 0 = toyFatherBeatIndex + 1
    ∧ godWeight toyBeatBudget toyBeatBudget = 1
    ∧ godWeight toyBeatBudget 1 + 1 = toyBeatBudget + 1 :=
  ⟨mnemonic_three_beats_ceiling, godweight_two_son_slots_floor, one_pass_rejection_conservation⟩

/--
  Son-slot mnemonic: **`v` aliases beat index** on `{0,1}` with **`R = toyBeatBudget`.**
  Then **`godWeight R 0 = 3`** and **`godWeight R 1 = 2`** — younger shadow inherits **more** mass.
-/
theorem younger_son_shadow_inherits_strictly_more_earth_via_godweight_than_elder :
    godWeight toyBeatBudget toyYoungerBrotherIndex
      > godWeight toyBeatBudget toyElderBrotherIndex := by
  simp only [godWeight, toyBeatBudget, toyYoungerBrotherIndex, toyElderBrotherIndex]
  decide

abbrev propOf {p : Prop} (_ : p) : Prop :=
  p

def ProdigalStructuralWitness : Prop :=
  (toyYoungerBrotherIndex < toyElderBrotherIndex ∧ toyElderBrotherIndex < toyFatherBeatIndex)
    ∧ ((propOf Gnosis.ZenosArrowWitness.arrows_at_rest_trajectory_moves_witness
        ∧ propOf Gnosis.AchillesTortoiseLadder.achilles_tortoise_witness
        ∧ Gnosis.InfinityPath.ladderPath.span = 12)
      ∧ (godWeight toyBeatBudget 0 = toyFatherBeatIndex + 1))

theorem prodigalStructuralWitness : ProdigalStructuralWitness :=
  And.intro toy_beats_strict_chain
    (And.intro
      (And.intro Gnosis.ZenosArrowWitness.arrows_at_rest_trajectory_moves_witness
        (And.intro Gnosis.AchillesTortoiseLadder.achilles_tortoise_witness
          Gnosis.InfinityPath.ladder_span))
      mnemonic_three_beats_ceiling)

