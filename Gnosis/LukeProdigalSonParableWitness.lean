theorem prodigal_conjuncts (Y E F G : Prop) (w : ProdigalTwoSonsWitness Y E F G) : Y ∧ E ∧ F ∧ G :=
  And.intro w.joplinFloor (And.intro w.marcuseElder (And.intro w.dalinianBreak w.graceInvariant))

def buildProdigalWitness (Y E F G : Prop) (hY : Y) (hE : E) (hF : F) (hG : G) : ProdigalTwoSonsWitness Y E F G :=
