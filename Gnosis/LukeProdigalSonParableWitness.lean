/-- Beat index: younger son. -/
def toyYoungerBrotherIndex : Nat := 0

/-- Beat index: elder son. -/
def toyElderBrotherIndex : Nat := 1

/-- Beat index: father / feast closure in this encoding. -/
def toyFatherBeatIndex : Nat := 2

/-- God-formula budget `R`: two son-slots before the paternal beat. -/
def toyBeatBudget : Nat := 2

theorem toy_beats_strict_chain :
    toyYoungerBrotherIndex < toyElderBrotherIndex ∧ toyElderBrotherIndex < toyFatherBeatIndex := by
  constructor <;> decide

/-- Narrative order: younger then elder then father — strict sequential beats. -/
theorem ledger_two_sons_then_father_sequential :
    toyYoungerBrotherIndex < toyElderBrotherIndex ∧ toyElderBrotherIndex < toyFatherBeatIndex :=
  toy_beats_strict_chain

theorem three_disjoint_beat_slots :
    toyYoungerBrotherIndex ≠ toyElderBrotherIndex
    ∧ toyElderBrotherIndex ≠ toyFatherBeatIndex
    ∧ toyYoungerBrotherIndex ≠ toyFatherBeatIndex := by
  constructor <;> decide

/-! ### Triton `{-1, 0, 1}` (`Gnosis.GrandReductionTriton`)

Caricature-only mapping of beats to signed poles; father is equilibrium (`0`),
not “God” in the `CosmicTrinity` sense — see `GrandReductionTriton` commentary. -/

/-- Younger beat ↔ `+1` (expansion / agent pole in triton docstring). -/
def tritonYoungerCaricature : Int := 1

/-- Elder beat ↔ `−1` (contraction / operator pole). -/
def tritonElderCaricature : Int := -1

/-- Father / feast beat ↔ `0` (equilibrium — fold). -/
def tritonFatherCaricature : Int := 0

theorem prodigal_triton_three_values :
    tritonYoungerCaricature = 1 ∧ tritonElderCaricature = -1 ∧ tritonFatherCaricature = 0 :=
  And.intro rfl (And.intro rfl rfl)

theorem prodigal_triton_pairwise_distinct :
    tritonYoungerCaricature ≠ tritonElderCaricature
    ∧ tritonElderCaricature ≠ tritonFatherCaricature
    ∧ tritonYoungerCaricature ≠ tritonFatherCaricature := by
  constructor <;> decide

theorem triton_compute_positive : GrandReductionTriton.computeTriton 4 = 1 := rfl

theorem triton_compute_negative : GrandReductionTriton.computeTriton (-4) = -1 := rfl

theorem triton_compute_equilibrium : GrandReductionTriton.computeTriton 0 = 0 := rfl

/-- Kernel hooks: `computeTriton` stable branches match `{-1,0,1}` classification. -/
theorem triton_compute_hooks :
    GrandReductionTriton.computeTriton 4 = 1
    ∧ GrandReductionTriton.computeTriton (-4) = -1
    ∧ GrandReductionTriton.computeTriton 0 = 0 :=
  ⟨triton_compute_positive, triton_compute_negative, triton_compute_equilibrium⟩

theorem toy_father_index_after_both_brothers :
    toyYoungerBrotherIndex < toyFatherBeatIndex ∧ toyElderBrotherIndex < toyFatherBeatIndex :=
  ⟨Nat.lt_trans toy_beats_strict_chain.left toy_beats_strict_chain.right,
    toy_beats_strict_chain.right⟩

/-- Son slots strictly precede father — fork + race beats lie before fold on the `Nat` spine. -/
theorem scheduling_fork_and_race_slots_before_fold :
    toyYoungerBrotherIndex < toyFatherBeatIndex ∧ toyElderBrotherIndex < toyFatherBeatIndex :=
  toy_father_index_after_both_brothers

