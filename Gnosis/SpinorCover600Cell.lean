-- ════════ Kernel = {±1}, image = icosahedral rotation group (60), cover index 2 ════════
namespace Cover
open GR ZPhi

-- the scaled identity rotation R(+1) (= 4·I₃ on the ×2-scaled +1)
def RIdent : M3 := RmatZ qOne

-- kernel: icosians whose conjugation rotation equals R(+1)
def icosaKernel : List QZ := icosa.filter (fun q => decide (RmatZ q = RIdent))

-- distinct-rotation de-duplication
def nubM3 (l : List M3) : List M3 :=
  l.foldl (fun acc m => if acc.contains m then acc else acc ++ [m]) []
def icosaImage : List M3 := nubM3 (icosa.map RmatZ)

theorem icosa_kernel_is_pm_one :
    icosaKernel = [qOne, qNeg1] ∧ icosaKernel.length = 2 := by
  refine ⟨by decide, by decide⟩

theorem icosa_neg_invariant :
    (icosa.all (fun q => decide (RmatZ q = RmatZ (qnegZ q)))) = true := by decide

theorem icosa_image_card_is_sixty :
    icosaImage.length = 60 ∧ icosa.length / icosaImage.length = 2 := by
  refine ⟨by decide, by decide⟩

end Cover

-- ════════════════════════════════════════════════════════════
-- §9  Master certificate — the 2I cover, computed
-- ════════════════════════════════════════════════════════════

namespace Cover
open GR ZPhi

/-- **SPINOR-COVER-600-CELL (master).** The SU(2) → SO(3) double cover realized by the
    EXACT ℤ[φ] conjugation rotation `RmatZ` on the binary icosahedral group 2I (the 120
    icosian units = the 600-cell vertices):

      (a) UNIVERSAL HOMOMORPHISM: `RmatZ (qmulZ p q) = mmulZ (RmatZ p) (RmatZ q)` for
          EVERY pair of ℤ[φ]-quaternions (`hom_bridge`) — proved as a polynomial identity,
          NOT by enumerating the 14400 pairs of 2I.
      (b) CLOSURE: the explicit 120-element icosian list has length 120 (`icosa_card`) and
          is closed under multiplication by the two generators (`icosa_gen_closed`).
      (c) `RmatZ q = RmatZ (−q)` for every icosian (`icosa_neg_invariant`), so −1 lies in
          the kernel and the cover is (at least) 2:1.
      (d) KERNEL = {±1}: exactly the two central units map to the identity rotation
          (`icosa_kernel_is_pm_one`).
      (e) IMAGE = 60 = |A₅| (the icosahedral rotation group), cover index 120 / 60 = 2
          (`icosa_image_card_is_sixty`).

    This is the COMPUTED conjugation lift of the order-level shadow in
    `OrientationE8Bridge`; it is the finite restriction of the continuous cover, not the
    continuous cover. -/
theorem spinor_cover_600cell_master :
    (∀ p q : QZ, RmatZ (qmulZ p q) = mmulZ (RmatZ p) (RmatZ q))
    ∧ icosa.length = 120
    ∧ (icosa.all (fun a => gens2.all (fun g => icosa.contains (qmulS a g)))) = true
    ∧ (icosa.all (fun q => decide (RmatZ q = RmatZ (qnegZ q)))) = true
    ∧ (icosaKernel = [qOne, qNeg1] ∧ icosaKernel.length = 2)
    ∧ (icosaImage.length = 60 ∧ icosa.length / icosaImage.length = 2) := by
  refine ⟨hom_bridge, icosa_card, icosa_gen_closed, icosa_neg_invariant,
          icosa_kernel_is_pm_one, icosa_image_card_is_sixty⟩

/-- **The computed 2I cover index equals the order-level shadow.** The index 2 computed
    here from the conjugation rotation (`|2I| / |image| = 120 / 60 = 2`) equals the
    tabulated `Gnosis.OrientationE8Bridge.spinCoverIndex`, and the carrier/image counts match the
    order-arithmetic `subgroupOrder .BinaryIcosa / rotationOrder .Icosa = 120 / 60`. The
    conjugation computation reproduces — and lifts — `binary_is_2to1_spin_cover` and
    `icosa_spin_cover_lands_on_E8` for the icosahedral case. -/
theorem icosa_cover_index_ties_to_shadow :
    icosa.length / icosaImage.length = Gnosis.OrientationE8Bridge.spinCoverIndex
    ∧ icosa.length = ADEMcKayCorrespondence.subgroupOrder .BinaryIcosa 0
    ∧ icosaImage.length = Gnosis.OrientationE8Bridge.rotationOrder .Icosa
    ∧ icosa.length / icosaImage.length
        = ADEMcKayCorrespondence.subgroupOrder .BinaryIcosa 0
            / Gnosis.OrientationE8Bridge.rotationOrder .Icosa := by
  refine ⟨by decide, by decide, by decide, by decide⟩

end Cover

