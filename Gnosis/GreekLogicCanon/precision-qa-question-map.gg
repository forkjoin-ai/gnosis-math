(sub_indicators: PrecisionQASubcategory { subcategory: 'indicators', category: 'effects', format: 'truth_conclusion' })
(sub_risk_assessment: PrecisionQASubcategory { subcategory: 'risk-assessment', category: 'effects', format: 'truth_conclusion' })
(sub_accountability: PrecisionQASubcategory { subcategory: 'accountability', category: 'action', format: 'rule_conclusion' })
(sub_containment_vs_prevention: PrecisionQASubcategory { subcategory: 'containment-vs-prevention', category: 'action', format: 'rule_conclusion' })
