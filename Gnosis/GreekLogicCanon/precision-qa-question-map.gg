(sub_stakeholders: PrecisionQASubcategory { subcategory: 'stakeholders', category: 'effects', format: 'truth_conclusion' })
(sub_time_span: PrecisionQASubcategory { subcategory: 'time-span', category: 'effects', format: 'truth_conclusion' })
(sub_multiple_scenarios: PrecisionQASubcategory { subcategory: 'multiple-scenarios', category: 'effects', format: 'truth_conclusion' })
