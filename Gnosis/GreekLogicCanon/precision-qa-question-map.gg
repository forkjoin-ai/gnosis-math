(sub_category: PrecisionQASubcategory { subcategory: 'category', category: 'assumptions', format: 'truth_premise' })
(sub_similarity: PrecisionQASubcategory { subcategory: 'similarity', category: 'assumptions', format: 'truth_premise' })
(sub_time_constancy: PrecisionQASubcategory { subcategory: 'time-constancy', category: 'assumptions', format: 'truth_premise' })
