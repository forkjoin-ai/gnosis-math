// Precision Q&A category/subcategory bridge for question-vacuum topology.
// The 7 product-facing categories and 42 subcategories map into finite
// QuestionFormat tags used by aeon-logic closure proposals.

(precision_qa_categories: PrecisionQACategoryCatalog { expectedCount: '7', subcategoryCount: '42', leanModule: 'Gnosis.GreekLogicCanon.QuestionVacuum' })

(truth_premise: QuestionFormat { format: 'truth_premise', kind: 'truth', slot: 'premise' })
(truth_conclusion: QuestionFormat { format: 'truth_conclusion', kind: 'truth', slot: 'conclusion' })
(truth_witness: QuestionFormat { format: 'truth_witness', kind: 'truth', slot: 'witness' })
(term_witness: QuestionFormat { format: 'term_witness', kind: 'term', slot: 'witness' })
(rule_connector: QuestionFormat { format: 'rule_connector', kind: 'rule', slot: 'connector' })
(rule_conclusion: QuestionFormat { format: 'rule_conclusion', kind: 'rule', slot: 'conclusion' })

(cat_focus: PrecisionQACategory { category: 'focus', format: 'rule_connector', subcategoryCount: '5' })
(cat_clarification: PrecisionQACategory { category: 'clarification', format: 'term_witness', subcategoryCount: '6' })
(cat_assumptions: PrecisionQACategory { category: 'assumptions', format: 'truth_premise', subcategoryCount: '9' })
(cat_evidence: PrecisionQACategory { category: 'evidence', format: 'truth_witness', subcategoryCount: '5' })
(cat_causes: PrecisionQACategory { category: 'causes', format: 'rule_connector', subcategoryCount: '6' })
(cat_effects: PrecisionQACategory { category: 'effects', format: 'truth_conclusion', subcategoryCount: '6' })
(cat_action: PrecisionQACategory { category: 'action', format: 'rule_conclusion', subcategoryCount: '5' })

(precision_qa_categories)-[:CONTAINS]->(cat_focus)
(precision_qa_categories)-[:CONTAINS]->(cat_clarification)
(precision_qa_categories)-[:CONTAINS]->(cat_assumptions)
(precision_qa_categories)-[:CONTAINS]->(cat_evidence)
(precision_qa_categories)-[:CONTAINS]->(cat_causes)
(precision_qa_categories)-[:CONTAINS]->(cat_effects)
(precision_qa_categories)-[:CONTAINS]->(cat_action)

(cat_focus)-[:TAGGED]->(rule_connector)
(cat_clarification)-[:TAGGED]->(term_witness)
(cat_assumptions)-[:TAGGED]->(truth_premise)
(cat_evidence)-[:TAGGED]->(truth_witness)
(cat_causes)-[:TAGGED]->(rule_connector)
(cat_effects)-[:TAGGED]->(truth_conclusion)
(cat_action)-[:TAGGED]->(rule_conclusion)

(sub_mental_ecology: PrecisionQASubcategory { subcategory: 'mental-ecology', category: 'focus', format: 'rule_connector' })
(sub_motivation: PrecisionQASubcategory { subcategory: 'motivation', category: 'focus', format: 'rule_connector' })
(sub_participation: PrecisionQASubcategory { subcategory: 'participation', category: 'focus', format: 'rule_connector' })
(sub_communication_channel: PrecisionQASubcategory { subcategory: 'communication-channel', category: 'focus', format: 'rule_connector' })
(sub_discussion_direction: PrecisionQASubcategory { subcategory: 'discussion-direction', category: 'focus', format: 'rule_connector' })
(sub_ambiguity: PrecisionQASubcategory { subcategory: 'ambiguity', category: 'clarification', format: 'term_witness' })
(sub_vagueness: PrecisionQASubcategory { subcategory: 'vagueness', category: 'clarification', format: 'term_witness' })
(sub_slippery_terms: PrecisionQASubcategory { subcategory: 'slippery-terms', category: 'clarification', format: 'term_witness' })
(sub_mental_graph: PrecisionQASubcategory { subcategory: 'mental-graph', category: 'clarification', format: 'term_witness' })
