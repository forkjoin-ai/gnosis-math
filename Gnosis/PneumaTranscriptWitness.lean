def transcriptCertificate : Gnosis.UniversalStandingWaveTheorem.TranscriptStandingWaveCertificate :=
  { turns := transcriptTurns
    carriers := transcriptCarriers
    tags := transcriptTags }

theorem transcript_segmentation_covers_carriers :
    SegmentationCoversCarriers transcriptTurns transcriptCarriers := by
  unfold SegmentationCoversCarriers
  native_decide

theorem transcript_tags_cover_turns :
    TagsCoverTurns transcriptTags transcriptTurns := by
  unfold TagsCoverTurns
  native_decide

theorem transcript_well_formed_tags :
    WellFormedTranscriptTags 100 transcriptTags := by
  unfold WellFormedTranscriptTags TagAttachedToCarrier TagConfidenceBoundedBy
  native_decide

theorem transcript_admissible :
    Gnosis.UniversalStandingWaveTheorem.TranscriptCertificateAdmissible 100 transcriptCertificate := by
  exact ⟨transcript_segmentation_covers_carriers,
    transcript_tags_cover_turns,
    transcript_well_formed_tags⟩

theorem transcript_tags_project_to_carriers :
    transcriptTags.map (fun tag => tag.carrier) = transcriptCarriers :=
  Gnosis.UniversalStandingWaveTheorem.transcript_certificate_tags_project_to_carriers 100
    transcriptCertificate transcript_admissible

end PneumaTranscriptWitness
