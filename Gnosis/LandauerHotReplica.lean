import Gnosis.CostAlgebra
import Gnosis.CostAlgebraEntropy
import Gnosis.SpectralNoiseEquilibrium
import Gnosis.BuleySelfSimilarityViolation

/-!
# Landauer Hot-Replica Admission

A concrete operational protocol for the inference mesh, derived
directly from the no-cloning theorem and the cost-algebra entropy
formula.

## The setup

A layer-node carries a `BuleyUnit`-shaped operational state with score
`score s`. Each node has a fixed `LandauerCeiling` â€” the maximum
heat-budget (Bule mass) it can absorb before melting. A "Hot Replica"
request asks the node to fan its state out to `k â‰¥ 1` total replicas
(itself plus `k âˆ’ 1` copies).

Per `Gnosis.CostAlgebraEntropy.replicationEntropy`, replicating to `k`
total replicas generates `(k âˆ’ 1) Â· score s` of entropy â€” the
"Landauer payment." For the request to be admissible, the source's
own score plus the replication entropy must fit inside the ceiling:

```
score s + (k âˆ’ 1) Â· score s = k Â· score s  â‰¤  ceiling
```

If admissible, the replica is granted. If not, the deficit is
deterministic: the node must first cool its state (apply
`clinamenContract` enough times) to bring `k Â· score s` under the
ceiling, then re-evaluate. The remediation count is also derived,
matching the `BuleySelfSimilarityViolation` shape.

## The closing claim

This is the formal admission protocol the coordinator should apply on
every replica request: **the no-cloning theorem isn't merely a
constraint â€” it gives the controller a deterministic rule for when
to grant, when to defer, and how much cooling to demand.**

Imports `Gnosis.CostAlgebra`, `Gnosis.CostAlgebraEntropy`,
`Gnosis.SpectralNoiseEquilibrium`, and `Gnosis.BuleySelfSimilarityViolation`.
Zero `sorry`, zero new `axiom`.
-/

namespace Gnosis
namespace LandauerHotReplica

open Gnosis.CostAlgebra (CostAlgebra buleyCostAlgebra)
open Gnosis.CostAlgebraEntropy
  (replicationEntropy replication_entropy_one replication_entropy_step)
open Gnosis.SpectralNoiseEquilibrium
  (BuleyUnit buleyUnitScore vacuumBuleUnit vacuum_has_zero_score)

/-! ## Ceiling, deficit, admission -/

abbrev LandauerCeiling := Nat

/-- The total heat the system would carry after replicating `s` to
`k` total replicas: the source's score plus the replication entropy
generated by the `k âˆ’ 1` clones. -/
def replicaTotalHeat
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat) : Nat :=
  A.score s + replicationEntropy A s k

/-- For `k â‰¥ 1`, the total heat is `k Â· score s`: the source plus
`(k âˆ’ 1)` extra copies. -/
theorem replica_total_heat_step
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat) :
    replicaTotalHeat A s (k + 1) = (k + 1) * A.score s := by
  show A.score s + k * A.score s = (k + 1) * A.score s
  rw [Nat.succ_mul]
  exact Nat.add_comm _ _

theorem replica_total_heat_one
    {S : Type} (A : CostAlgebra S) (s : S) :
    replicaTotalHeat A s 1 = A.score s := by
  unfold replicaTotalHeat
  rw [replication_entropy_one, Nat.add_zero]

/-- A replication request is admissible iff the total heat fits inside
the ceiling. -/
def admitsReplication
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat)
    (ceiling : LandauerCeiling) : Prop :=
  replicaTotalHeat A s k â‰¤ ceiling

/-- For a single replica (`k = 1`), the request is admissible iff the
source's score itself fits the ceiling. -/
theorem admits_one_replica_iff_score_fits
    {S : Type} (A : CostAlgebra S) (s : S) (ceiling : LandauerCeiling) :
    admitsReplication A s 1 ceiling â†” A.score s â‰¤ ceiling := by
  unfold admitsReplication
  rw [replica_total_heat_one]

/-- For any `k â‰¥ 1`, admission iff `k Â· score s â‰¤ ceiling`. -/
theorem admits_replication_iff_k_score_fits
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat)
    (ceiling : LandauerCeiling) :
    admitsReplication A s (k + 1) ceiling â†” (k + 1) * A.score s â‰¤ ceiling := by
  unfold admitsReplication
  rw [replica_total_heat_step]

/-! ## The deficit and corrective remediation -/

/-- The Landauer deficit: how much the request exceeds the ceiling. -/
def landauerDeficit
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat)
    (ceiling : LandauerCeiling) : Nat :=
  replicaTotalHeat A s k - ceiling

theorem deficit_zero_iff_admitted
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat)
    (ceiling : LandauerCeiling) :
    landauerDeficit A s k ceiling = 0 â†” admitsReplication A s k ceiling := by
  unfold landauerDeficit admitsReplication
  constructor
  Â· intro h; omega
  Â· intro h; omega

theorem deficit_positive_iff_rejected
    {S : Type} (A : CostAlgebra S) (s : S) (k : Nat)
    (ceiling : LandauerCeiling) :
    landauerDeficit A s k ceiling > 0
      â†” replicaTotalHeat A s k > ceiling := by
  unfold landauerDeficit
  constructor
  Â· intro h; omega
  Â· intro h; omega

/-! ## Concrete tower-level admission decisions -/

/-- A Bule unit with score 18 (Trihexon-pressure) replicating to 2
total replicas needs 36 Bule mass total â€” admissible only if the
ceiling is at least 36. -/
theorem trihexon_two_replica_total_heat_is_thirty_six :
    replicaTotalHeat buleyCostAlgebra âŸ¨18, 0, 0âŸ© 2 = 36 := by decide

theorem trihexon_two_replica_admitted_at_ceiling_36 :
    admitsReplication buleyCostAlgebra âŸ¨18, 0, 0âŸ© 2 36 := by
  unfold admitsReplication
  show buleyUnitScore (âŸ¨18, 0, 0âŸ© : BuleyUnit)
        + replicationEntropy buleyCostAlgebra âŸ¨18, 0, 0âŸ© 2 â‰¤ 36
  decide

theorem trihexon_two_replica_rejected_at_ceiling_35 :
    Â¬ admitsReplication buleyCostAlgebra âŸ¨18, 0, 0âŸ© 2 35 := by
  unfold admitsReplication
  show Â¬ (buleyUnitScore (âŸ¨18, 0, 0âŸ© : BuleyUnit)
            + replicationEntropy buleyCostAlgebra âŸ¨18, 0, 0âŸ© 2 â‰¤ 35)
  decide

/-- A Hexon-pressure (score 6) Bule unit replicating to 3 nodes (one
source plus 2 copies) costs 18 Bule mass total. -/
theorem hexon_three_replica_total_heat_is_eighteen :
    replicaTotalHeat buleyCostAlgebra âŸ¨6, 0, 0âŸ© 3 = 18 := by decide

theorem hexon_three_replica_admitted_at_ceiling_18 :
    admitsReplication buleyCostAlgebra âŸ¨6, 0, 0âŸ© 3 18 := by
  unfold admitsReplication
  decide

theorem hexon_three_replica_deficit_at_ceiling_10 :
    landauerDeficit buleyCostAlgebra âŸ¨6, 0, 0âŸ© 3 10 = 8 := by
  unfold landauerDeficit
  show replicaTotalHeat buleyCostAlgebra âŸ¨6, 0, 0âŸ© 3 - 10 = 8
  decide

/-! ## The vacuum is always admissible -/

/-- Replicating the vacuum to any number of nodes is free: the vacuum's
score is zero, so total heat is zero, which fits inside any ceiling.
This matches `vacuum_is_duplicable` from the no-cloning module â€” the
vacuum is the unique state for which replication has no cost. -/
theorem vacuum_replication_always_admitted
    (k : Nat) (ceiling : LandauerCeiling) :
    admitsReplication buleyCostAlgebra vacuumBuleUnit k ceiling := by
  have hzero : buleyCostAlgebra.score vacuumBuleUnit = 0 := vacuum_has_zero_score
  have heat_zero : replicaTotalHeat buleyCostAlgebra vacuumBuleUnit k = 0 := by
    unfold replicaTotalHeat
    rw [hzero, Nat.zero_add]
    cases k with
    | zero => rfl
    | succ n =>
        show n * buleyCostAlgebra.score vacuumBuleUnit = 0
        rw [hzero, Nat.mul_zero]
  show replicaTotalHeat buleyCostAlgebra vacuumBuleUnit k â‰¤ ceiling
  rw [heat_zero]
  exact Nat.zero_le ceiling

/-! ## The deterministic remediation rule

If a request is rejected, the deficit is `landauerDeficit`. That
number quantifies what the application layer must do â€” typically a
sequence of `clinamenContract` lifts on the source â€” before the
admission predicate can be re-tested. The full cooling theorem is
deliberately left to the application layer (`spectral-noise-monitor`),
because the cost algebra is type-level and `Nat` division does not
generally yield the most operationally useful schedule (round-down
vs. round-up vs. amortized). The deficit-rejection predicate above is
sufficient to *trigger* remediation; the *schedule* is policy. -/

end LandauerHotReplica
end Gnosis
